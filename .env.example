# ─────────────────────────────────────────────────────────────
#  follow-upGary — Agent System Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail SMTP — for sending outbound SMS via T-Mobile gateway ──
# The Gmail address your texts go out from
GMAIL_ADDRESS=youremail@gmail.com
# 16-character app password (not your regular password)
# Generate at: myaccount.google.com/apppasswords
# (Requires 2FA to be enabled on the account)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Gmail OAuth token — for reading inbound SMS replies ──
# Run `python auth_setup.py` once locally to generate this.
# Paste the entire contents of token.json as one line here.
GMAIL_TOKEN={"token":"ya29...","refresh_token":"1//...","token_uri":"https://oauth2.googleapis.com/token","client_id":"....apps.googleusercontent.com","client_secret":"...","scopes":["https://www.googleapis.com/auth/gmail.modify"]}

# ── Google Sheets — for reading/writing contacts ──
# The long ID from your spreadsheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Paste the entire contents of your service account JSON key file here as one line.
# Create at: console.cloud.google.com → IAM → Service Accounts → Keys → Add Key → JSON
# Then share your Google Sheet with the service account email address.
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-agent@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Notifications ──
# Where to send booking and referral alerts (can be same as GMAIL_ADDRESS)
OWNER_EMAIL=youremail@gmail.com
